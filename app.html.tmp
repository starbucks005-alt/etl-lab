<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SLR Studio — AI-Powered Systematic Literature Review</title>
<meta name="description" content="SLR Studio helps researchers and faculty conduct rigorous systematic literature reviews with AI-assisted keyword generation, gap analysis, and manuscript drafting.">
<link rel="icon" type="image/png" href="https://raw.githubusercontent.com/Oroszi/slr-studio-assets/main/W%20Logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:   #1a1a18;
    --paper: #f5f3ee;
    --gold:  #c9903a;
    --gold2: #e8b86d;
    --muted: #6b6b65;
    --green: #2d6a4f;
    --red:   #8b1a1a;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Outfit', sans-serif; background: var(--ink); color: var(--paper); line-height: 1.6; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 40px; height: 64px;
    background: rgba(26,26,24,0.95); backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-logo { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--paper); text-decoration: none; }
  .nav-logo span { color: var(--gold); }
  .nav-links { display: flex; align-items: center; gap: 32px; }
  .nav-links a { color: rgba(245,243,238,0.6); text-decoration: none; font-size: 14px; transition: color 0.2s; }
  .nav-links a:hover { color: var(--paper); }
  .nav-cta { padding: 8px 20px; background: var(--gold); color: var(--ink); font-weight: 600; font-size: 13px; border: none; cursor: pointer; text-decoration: none; transition: opacity 0.2s; }
  .nav-cta:hover { opacity: 0.88; }

  /* HERO */
  .hero {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 100px 24px 80px;
    background: radial-gradient(ellipse at 50% 0%, rgba(201,144,58,0.12) 0%, transparent 60%);
  }
  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 24px;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif; font-size: clamp(40px, 6vw, 72px);
    font-weight: 700; line-height: 1.1; max-width: 820px; margin: 0 auto 24px;
  }
  .hero h1 em { font-style: normal; color: var(--gold); }
  .hero-sub {
    font-size: clamp(16px, 2vw, 20px); color: rgba(245,243,238,0.65);
    max-width: 580px; margin: 0 auto 48px;
  }
  .hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    padding: 14px 36px; background: var(--gold); color: var(--ink);
    font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 15px;
    border: none; cursor: pointer; text-decoration: none; transition: opacity 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { opacity: 0.88; }
  .btn-secondary {
    padding: 14px 36px; background: transparent; color: var(--paper);
    font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 15px;
    border: 1px solid rgba(255,255,255,0.25); cursor: pointer; text-decoration: none;
    transition: border-color 0.2s; display: inline-block;
  }
  .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }
  .hero-proof {
    margin-top: 64px; display: flex; gap: 48px; justify-content: center;
    flex-wrap: wrap;
  }
  .proof-stat { text-align: center; }
  .proof-num { font-family: 'Playfair Display', serif; font-size: 36px; color: var(--gold); }
  .proof-label { font-size: 12px; color: rgba(245,243,238,0.5); letter-spacing: 0.06em; text-transform: uppercase; margin-top: 4px; }

  /* FEATURES */
  .section { padding: 100px 24px; max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 16px;
  }
  .section-title {
    font-family: 'Playfair Display', serif; font-size: clamp(28px, 4vw, 44px);
    font-weight: 700; margin-bottom: 16px;
  }
  .section-sub { color: rgba(245,243,238,0.6); font-size: 17px; max-width: 560px; }
  .features-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2px; margin-top: 64px; background: rgba(255,255,255,0.04);
  }
  .feature-card {
    background: var(--ink); padding: 40px 32px;
    border: 1px solid rgba(255,255,255,0.06);
    transition: border-color 0.2s;
  }
  .feature-card:hover { border-color: rgba(201,144,58,0.3); }
  .feature-icon { font-size: 28px; margin-bottom: 20px; }
  .feature-title { font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 10px; }
  .feature-desc { color: rgba(245,243,238,0.6); font-size: 14px; line-height: 1.65; }

  /* WORKFLOW */
  .workflow { padding: 80px 24px; background: rgba(255,255,255,0.02); }
  .workflow-inner { max-width: 900px; margin: 0 auto; text-align: center; }
  .steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 32px; margin-top: 56px; }
  .step { text-align: center; }
  .step-num {
    width: 48px; height: 48px; border: 1px solid var(--gold); border-radius: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 14px; color: var(--gold);
    margin: 0 auto 16px;
  }
  .step-title { font-weight: 600; font-size: 14px; margin-bottom: 6px; }
  .step-desc { color: rgba(245,243,238,0.5); font-size: 13px; }

  /* PRICING */
  #pricing { padding: 100px 24px; }
  .pricing-inner { max-width: 1060px; margin: 0 auto; }
  .pricing-header { text-align: center; margin-bottom: 48px; }
  .billing-toggle {
    display: inline-flex; gap: 0; border: 1px solid rgba(255,255,255,0.15);
    margin-bottom: 56px;
  }
  .toggle-btn {
    padding: 10px 28px; background: transparent; color: rgba(245,243,238,0.5);
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; border: none; cursor: pointer; transition: all 0.2s;
  }
  .toggle-btn.active {
    background: var(--gold); color: var(--ink); font-weight: 600;
  }
  .save-badge {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.08em;
    background: rgba(45,106,79,0.3); color: #6fcf97; border: 1px solid rgba(111,207,151,0.3);
    padding: 3px 8px; margin-left: 8px;
  }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  @media (max-width: 768px) { .pricing-grid { grid-template-columns: 1fr; } }
  .plan-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
    padding: 40px 32px; position: relative; transition: border-color 0.2s;
  }
  .plan-card:hover { border-color: rgba(201,144,58,0.4); }
  .plan-card.featured {
    background: rgba(201,144,58,0.07); border-color: rgba(201,144,58,0.5);
  }
  .plan-badge {
    position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.12em;
    text-transform: uppercase; background: var(--gold); color: var(--ink);
    padding: 4px 16px; font-weight: 600;
  }
  .plan-name { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .plan-desc { color: rgba(245,243,238,0.5); font-size: 13px; margin-bottom: 28px; }
  .plan-price-wrap { margin-bottom: 32px; }
  .plan-price { font-family: 'Playfair Display', serif; font-size: 48px; font-weight: 700; }
  .plan-price .currency { font-size: 24px; vertical-align: top; margin-top: 12px; display: inline-block; }
  .plan-price .period { font-family: 'Outfit', sans-serif; font-size: 14px; color: rgba(245,243,238,0.4); }
  .plan-yearly-note { font-size: 12px; color: rgba(245,243,238,0.4); margin-top: 6px; }
  .plan-features { list-style: none; margin-bottom: 36px; }
  .plan-features li { font-size: 14px; color: rgba(245,243,238,0.75); padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; gap: 10px; }
  .plan-features li::before { content: '✓'; color: var(--gold); flex-shrink: 0; }
  .plan-btn {
    width: 100%; padding: 14px; font-family: 'Outfit', sans-serif; font-weight: 600;
    font-size: 14px; cursor: pointer; border: none; transition: opacity 0.2s;
    letter-spacing: 0.04em;
  }
  .plan-btn-primary { background: var(--gold); color: var(--ink); }
  .plan-btn-ghost { background: transparent; color: var(--paper); border: 1px solid rgba(255,255,255,0.2); }
  .plan-btn:hover { opacity: 0.85; }
  .plan-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* TESTIMONIALS */
  .testimonials { padding: 80px 24px; background: rgba(255,255,255,0.02); }
  .testimonials-inner { max-width: 900px; margin: 0 auto; }
  .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; margin-top: 56px; }
  .testimonial {
    background: var(--ink); border: 1px solid rgba(255,255,255,0.06);
    padding: 32px; position: relative;
  }
  .testimonial::before { content: '"'; font-family: 'Playfair Display', serif; font-size: 72px; color: var(--gold); opacity: 0.25; position: absolute; top: 8px; left: 24px; line-height: 1; }
  .testimonial-text { font-size: 15px; color: rgba(245,243,238,0.8); line-height: 1.65; margin-bottom: 20px; position: relative; z-index: 1; }
  .testimonial-author { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--gold); letter-spacing: 0.08em; }
  .testimonial-role { font-size: 12px; color: rgba(245,243,238,0.4); margin-top: 2px; }

  /* FAQ */
  .faq { padding: 80px 24px; max-width: 720px; margin: 0 auto; }
  .faq-item { border-bottom: 1px solid rgba(255,255,255,0.07); }
  .faq-q {
    width: 100%; text-align: left; padding: 24px 0; background: none; border: none;
    color: var(--paper); font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 500;
    cursor: pointer; display: flex; justify-content: space-between; align-items: center;
  }
  .faq-q .arrow { color: var(--gold); transition: transform 0.2s; font-size: 20px; }
  .faq-q.open .arrow { transform: rotate(45deg); }
  .faq-a { display: none; padding: 0 0 20px; color: rgba(245,243,238,0.65); font-size: 15px; line-height: 1.7; }
  .faq-a.open { display: block; }

  /* FOOTER */
  footer {
    padding: 48px 40px 32px; border-top: 1px solid rgba(255,255,255,0.06);
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;
  }
  .footer-logo { font-family: 'Playfair Display', serif; font-size: 18px; }
  .footer-logo span { color: var(--gold); }
  .footer-links { display: flex; gap: 24px; }
  .footer-links a { color: rgba(245,243,238,0.4); font-size: 13px; text-decoration: none; }
  .footer-links a:hover { color: var(--paper); }
  .footer-copy { font-size: 12px; color: rgba(245,243,238,0.3); width: 100%; }

  /* TOAST */
  #toast {
    position: fixed; bottom: 32px; right: 32px; z-index: 999;
    background: #2d2d2a; border: 1px solid rgba(255,255,255,0.1);
    color: var(--paper); padding: 14px 24px; font-size: 14px;
    display: none; max-width: 320px;
  }
  #toast.show { display: block; }
  #toast.error { border-color: rgba(200,80,80,0.4); color: #f08080; }
</style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">SLR <span>Studio</span></a>
  <div class="nav-links">
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="#faq">FAQ</a>
    <a href="/login.html" style="color:rgba(245,243,238,0.6);">Sign In</a>
  </div>
  <a href="#pricing" class="nav-cta">Get Access →</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div>
    <div class="hero-eyebrow">AI-Powered Research Tool</div>
    <h1>Systematic Literature Reviews,<br><em>Done Right</em></h1>
    <p class="hero-sub">SLR Studio guides researchers and faculty from keyword generation to polished manuscript draft — with real paper retrieval, gap analysis, and AI writing assistance.</p>
    <div class="hero-actions">
      <a href="#pricing" class="btn-primary">Start Your Review →</a>
      <a href="/login.html" class="btn-secondary">Sign In</a>
    </div>
    <div class="hero-proof">
      <div class="proof-stat">
        <div class="proof-num">8</div>
        <div class="proof-label">Guided Modules</div>
      </div>
      <div class="proof-stat">
        <div class="proof-num">250M+</div>
        <div class="proof-label">Papers Indexed</div>
      </div>
      <div class="proof-stat">
        <div class="proof-num">APA · AMA · MLA</div>
        <div class="proof-label">Citation Styles</div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<div id="features">
  <div class="section">
    <div class="section-label">What You Get</div>
    <h2 class="section-title">Everything a literature review needs</h2>
    <p class="section-sub">From first keyword to final poster — a complete research workflow in one tool.</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🔍</div>
        <div class="feature-title">Smart Keyword Generation</div>
        <div class="feature-desc">AI generates PICO/SPIDER keyword clusters from your topic. Progressive narrowing finds the right scope automatically.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <div class="feature-title">Real Paper Retrieval</div>
        <div class="feature-desc">Live searches against 250M+ papers via OpenAlex. See actual counts, abstracts, and citations — no simulations.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🗺️</div>
        <div class="feature-title">PRISMA Protocol</div>
        <div class="feature-desc">Built-in PRISMA flowchart and inclusion/exclusion criteria. Export a complete protocol document for submission.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔬</div>
        <div class="feature-title">Gap Analysis</div>
        <div class="feature-desc">Identifies confirmed, thin, and emerging research gaps. Each gap is classified by cost tier with study design suggestions.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">✍️</div>
        <div class="feature-title">AI-Assisted Drafting</div>
        <div class="feature-desc">Generate Introduction, Methods, Results, and Discussion sections with in-text citations. Export as Word or plain text.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📝</div>
        <div class="feature-title">Grant Proposal Writing</div>
        <div class="feature-desc">Mid- and high-cost gaps link directly to a grant proposal writing module — critical for faculty with thesis students.</div>
      </div>
    </div>
  </div>
</div>

<!-- WORKFLOW -->
<div class="workflow">
  <div class="workflow-inner">
    <div class="section-label">The Process</div>
    <h2 class="section-title">From topic to manuscript in 8 steps</h2>
    <div class="steps">
      <div class="step"><div class="step-num">01</div><div class="step-title">Topic</div><div class="step-desc">Define your PICO research question</div></div>
      <div class="step"><div class="step-num">02</div><div class="step-title">Keywords</div><div class="step-desc">AI generates and refines search terms</div></div>
      <div class="step"><div class="step-num">03</div><div class="step-title">Preview</div><div class="step-desc">PRISMA protocol & scope review</div></div>
      <div class="step"><div class="step-num">04</div><div class="step-title">Build</div><div class="step-desc">Live paper retrieval by subgroup</div></div>
      <div class="step"><div class="step-num">05</div><div class="step-title">Foundation</div><div class="step-desc">Select and annotate key papers</div></div>
      <div class="step"><div class="step-num">06</div><div class="step-title">Draft</div><div class="step-desc">AI writes each manuscript section</div></div>
      <div class="step"><div class="step-num">07</div><div class="step-title">Gaps</div><div class="step-desc">Identify research gaps by cost tier</div></div>
      <div class="step"><div class="step-num">08</div><div class="step-title">Poster</div><div class="step-desc">Generate a conference poster</div></div>
    </div>
  </div>
</div>

<!-- PRICING -->
<section id="pricing">
  <div class="pricing-inner">
    <div class="pricing-header">
      <div class="section-label">Pricing</div>
      <h2 class="section-title">Simple, transparent access</h2>
      <p style="color:rgba(245,243,238,0.6);font-size:16px;margin-bottom:32px;">All plans include full tool access. Cancel anytime.</p>
      <div style="display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;">
        <div class="billing-toggle">
          <button class="toggle-btn active" id="toggle-monthly" onclick="setBilling('monthly')">Monthly</button>
          <button class="toggle-btn" id="toggle-yearly" onclick="setBilling('yearly')">Annual <span class="save-badge">Save ~30%</span></button>
        </div>
      </div>
    </div>

    <div class="pricing-grid">

      <!-- Individual -->
      <div class="plan-card">
        <div class="plan-name">Individual</div>
        <div class="plan-desc">Researchers, doctoral students, independent scholars</div>
        <div class="plan-price-wrap">
          <div class="plan-price">
            <span class="currency">$</span><span id="price-individual">29</span><span class="period"> /mo</span>
          </div>
          <div class="plan-yearly-note" id="note-individual">&nbsp;</div>
        </div>
        <ul class="plan-features">
          <li>Full SLR Studio access</li>
          <li>OpenAlex live paper search</li>
          <li>AI keyword generation</li>
          <li>Manuscript draft export</li>
          <li>Gap analysis + cost tiers</li>
          <li>1 user seat</li>
        </ul>
        <button class="plan-btn plan-btn-ghost" onclick="checkout('individual')">Get Started →</button>
      </div>

      <!-- Team (featured) -->
      <div class="plan-card featured">
        <div class="plan-badge">Most Popular</div>
        <div class="plan-name">Team</div>
        <div class="plan-desc">Research groups, lab cohorts, faculty + students</div>
        <div class="plan-price-wrap">
          <div class="plan-price">
            <span class="currency">$</span><span id="price-team">79</span><span class="period"> /mo</span>
          </div>
          <div class="plan-yearly-note" id="note-team">&nbsp;</div>
        </div>
        <ul class="plan-features">
          <li>Everything in Individual</li>
          <li>Up to 10 user seats</li>
          <li>Shared search history</li>
          <li>Priority support</li>
          <li>Grant proposal module</li>
          <li>Team billing</li>
        </ul>
        <button class="plan-btn plan-btn-primary" onclick="checkout('team')">Get Started →</button>
      </div>

      <!-- Institution -->
      <div class="plan-card">
        <div class="plan-name">Institution</div>
        <div class="plan-desc">Universities, research centers, departments</div>
        <div class="plan-price-wrap">
          <div class="plan-price">
            <span class="currency">$</span><span id="price-institution">299</span><span class="period"> /mo</span>
          </div>
          <div class="plan-yearly-note" id="note-institution">&nbsp;</div>
        </div>
        <ul class="plan-features">
          <li>Everything in Team</li>
          <li>Unlimited user seats</li>
          <li>Admin user dashboard</li>
          <li>SSO / SAML (on request)</li>
          <li>Usage analytics</li>
          <li>Dedicated onboarding</li>
        </ul>
        <button class="plan-btn plan-btn-ghost" onclick="checkout('institution')">Contact Us →</button>
      </div>

    </div>

    <p style="text-align:center;margin-top:32px;font-size:13px;color:rgba(245,243,238,0.35);">
      Graduating student? Ask your faculty advisor about gift access.
    </p>
  </div>
</section>

<!-- TESTIMONIALS -->
<div class="testimonials">
  <div class="testimonials-inner">
    <div style="text-align:center;">
      <div class="section-label">From Researchers</div>
      <h2 class="section-title">What faculty and students say</h2>
    </div>
    <div class="testimonials-grid">
      <div class="testimonial">
        <p class="testimonial-text">SLR Studio cut the time it takes my doctoral students to produce a defensible literature review from months to weeks. The gap analysis alone is worth the subscription.</p>
        <div class="testimonial-author">DR. M. OROSZI</div>
        <div class="testimonial-role">Associate Professor, Health Sciences</div>
      </div>
      <div class="testimonial">
        <p class="testimonial-text">I was stuck on which papers were relevant. The progressive keyword narrowing found exactly the right scope — and the PRISMA export was ready for my committee.</p>
        <div class="testimonial-author">DOCTORAL STUDENT</div>
        <div class="testimonial-role">Public Health, Year 3</div>
      </div>
      <div class="testimonial">
        <p class="testimonial-text">The cost-tier classification on research gaps is genuinely useful. It helps students know immediately whether they can proceed with a dissertation study or need grant funding.</p>
        <div class="testimonial-author">THESIS ADVISOR</div>
        <div class="testimonial-role">Department of Nursing Research</div>
      </div>
    </div>
  </div>
</div>

<!-- FAQ -->
<div id="faq" style="padding:80px 24px;max-width:720px;margin:0 auto;">
  <div style="text-align:center;margin-bottom:56px;">
    <div class="section-label">FAQ</div>
    <h2 class="section-title">Common questions</h2>
  </div>

  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">What happens after I pay? <span class="arrow">+</span></button>
    <div class="faq-a">Stripe processes your payment, then automatically creates your account and sends you an email with a link to set your password. The whole process takes under 2 minutes. If you don't receive the email within 5 minutes, check your spam folder or contact support.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">Can I cancel anytime? <span class="arrow">+</span></button>
    <div class="faq-a">Yes — no contracts, no cancellation fees. You can cancel from your account settings and your access continues until the end of your current billing period.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">Does SLR Studio use real papers or AI-fabricated citations? <span class="arrow">+</span></button>
    <div class="faq-a">Real papers only. SLR Studio searches OpenAlex, which indexes 250+ million scholarly works. Every paper in your results is a real, retrievable source with a real DOI or URL.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">What is "gift access" for graduating students? <span class="arrow">+</span></button>
    <div class="faq-a">Faculty advisors can grant complimentary access to graduating students who don't have institutional funding. Ask your advisor — this is handled through the admin dashboard and does not require a credit card.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">Does the Team plan support multiple users logging in separately? <span class="arrow">+</span></button>
    <div class="faq-a">Yes. Each user gets their own login credentials and their own search sessions. Team billing is consolidated to one invoice under the plan owner's account.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">Is my research data private? <span class="arrow">+</span></button>
    <div class="faq-a">Yes. Your searches, keywords, and manuscripts are stored only in your browser session unless you export them. We do not store your research content on our servers.</div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">SLR <span>Studio</span></div>
  <div class="footer-links">
    <a href="/login.html">Sign In</a>
    <a href="mailto:support@slrstudio.online">Support</a>
    <a href="#pricing">Pricing</a>
  </div>
  <div class="footer-copy">© 2025 SLR Studio. All rights reserved. · <a href="#" style="color:inherit;">Privacy Policy</a> · <a href="#" style="color:inherit;">Terms of Service</a></div>
</footer>

<div id="toast"></div>

<script>
// ── Billing toggle ──
let billingMode = 'monthly';
const prices = {
  monthly:  { individual: 29,   team: 79,   institution: 299  },
  yearly:   { individual: 249,  team: 649,  institution: 2499 },
};
const yearlyMonthly = {
  individual: Math.round(249/12),
  team:       Math.round(649/12),
  institution: Math.round(2499/12),
};

function setBilling(mode) {
  billingMode = mode;
  document.getElementById('toggle-monthly').classList.toggle('active', mode === 'monthly');
  document.getElementById('toggle-yearly').classList.toggle('active',  mode === 'yearly');

  ['individual','team','institution'].forEach(plan => {
    if (mode === 'monthly') {
      document.getElementById('price-' + plan).textContent = prices.monthly[plan].toLocaleString();
      document.getElementById('note-'  + plan).innerHTML = '&nbsp;';
    } else {
      document.getElementById('price-' + plan).textContent = yearlyMonthly[plan];
      document.getElementById('note-'  + plan).textContent = '$' + prices.yearly[plan].toLocaleString() + ' billed annually';
    }
  });
}

// ── Checkout ──
async function checkout(plan) {
  const priceId = plan + '_' + billingMode;
  showToast('Connecting to Stripe…', false);

  try {
    const res = await fetch('/.netlify/functions/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ priceId }),
    });

    if (!res.ok) {
      const text = await res.text();
      throw new Error(text || 'Server error');
    }

    const { url } = await res.json();
    window.location.href = url;
  } catch (err) {
    showToast('Error: ' + err.message, true);
  }
}

// ── FAQ ──
function toggleFaq(btn) {
  btn.classList.toggle('open');
  const answer = btn.nextElementSibling;
  answer.classList.toggle('open');
}

// ── Toast ──
function showToast(msg, isError) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'show' + (isError ? ' error' : '');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => { t.className = ''; }, 4000);
}

// ── Check if already logged in ──
(async () => {
  try {
    const SUPABASE_URL = '%%SUPABASE_URL%%';
    const SUPABASE_ANON = '%%SUPABASE_ANON_KEY%%';
    if (SUPABASE_URL.startsWith('%%')) return; // Not configured yet

    const { createClient } = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm');
    const sb = createClient(SUPABASE_URL, SUPABASE_ANON);
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      // Already logged in — add "Go to App" button to nav
      const nav = document.querySelector('.nav-links');
      const link = document.createElement('a');
      link.href = '/app.html';
      link.textContent = '→ Go to App';
      link.style.cssText = 'color:var(--gold);font-weight:600;';
      nav.appendChild(link);
    }
  } catch (_) {}
})();
</script>
</body>
